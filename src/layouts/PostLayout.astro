---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "./Layout.astro";
import JsonLd from "@/components/JsonLd.astro";
import { getPersonSchema } from "@/utils/getPersonSchema";
import config from "@/config";

type FaqItem = { question: string; answer: string };

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  tags?: string[];
  faq?: FaqItem[];
};

const { site } = config;

const {
  title,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
  faq,
} = Astro.props;

const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const inLanguage = site.lang === "ko" ? "ko-KR" : site.lang;
const person = getPersonSchema();

const blogPosting = {
  "@type": "BlogPosting",
  headline: title ?? site.title,
  ...(description && { description }),
  ...(ogImage && {
    image: {
      "@type": "ImageObject",
      url: ogImage,
      width: 1200,
      height: 630,
    },
  }),
  url: pageUrl,
  mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
  inLanguage,
  ...(tags && tags.length > 0 && { keywords: tags.join(", ") }),
  ...(pubDatetime && { datePublished: pubDatetime.toISOString() }),
  dateModified: (modDatetime ?? pubDatetime)?.toISOString(),
  author: [person],
  publisher: person,
};

const faqSchema =
  faq && faq.length > 0
    ? {
        "@type": "FAQPage",
        mainEntity: faq.map(item => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: { "@type": "Answer", text: item.answer },
        })),
      }
    : null;

const locale = Astro.currentLocale ?? site.lang;
const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: new URL(getRelativeLocaleUrl(locale, ""), Astro.site).href,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Posts",
      item: new URL(getRelativeLocaleUrl(locale, "posts"), Astro.site).href,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: title ?? site.title,
      item: pageUrl,
    },
  ],
};
---

<Layout {title} {description} {ogImage} {canonicalURL}>
  <Fragment slot="head">
    <!-- Override og:type for article pages -->
    <meta property="og:type" content="article" />

    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <JsonLd schema={blogPosting} />
    <JsonLd schema={breadcrumbSchema} />
    {faqSchema && <JsonLd schema={faqSchema} />}
  </Fragment>

  <slot />
</Layout>
