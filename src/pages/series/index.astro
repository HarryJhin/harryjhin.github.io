---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import SeriesCard from "@/components/SeriesCard.astro";
import { getSeriesList } from "@/utils/getSeries";
import { useTranslations } from "@/i18n";
import config from "@/config";

const posts = await getCollection("posts");
const seriesList = getSeriesList(posts);

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<Layout title={`${t.pages.seriesTitle} | ${config.site.title}`}>
  <Header />

  <Breadcrumb />

  <Main pageTitle={t.pages.seriesTitle} pageDesc={t.pages.seriesDesc}>
    {
      seriesList.length > 0 ? (
        <ul>
          {seriesList.map(group => (
            <SeriesCard {group} />
          ))}
        </ul>
      ) : (
        <p class="text-muted-foreground italic">{t.pages.seriesDesc}</p>
      )
    }
  </Main>

  <Footer />
</Layout>
