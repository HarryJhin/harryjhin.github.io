---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LeadStory from "@/components/LeadStory.astro";
import SectionIndex from "@/components/SectionIndex.astro";
import JsonLd from "@/components/JsonLd.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPersonSchema } from "@/utils/getPersonSchema";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const posts = await getCollection("posts");
const sorted = getSortedPosts(posts);
const lead = sorted.find(({ data }) => data.featured) ?? sorted[0];

const homePath = getRelativeLocaleUrl(locale, "");
const homeUrl = new URL(homePath, Astro.site).href;
const searchUrl = new URL(getRelativeLocaleUrl(locale, "search"), Astro.site)
  .href;
const inLanguage = config.site.lang === "ko" ? "ko-KR" : config.site.lang;

const websiteSchema = {
  "@type": "WebSite",
  name: config.site.title,
  url: homeUrl,
  description: config.site.description,
  inLanguage,
  publisher: getPersonSchema(),
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${searchUrl}?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
};
---

<Layout>
  <Fragment slot="head">
    <JsonLd schema={websiteSchema} />
  </Fragment>
  <Header variant="home" />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout flex flex-col gap-8 py-8"
  >
    {lead && <LeadStory post={lead} />}
    <SectionIndex posts={posts} excludeIds={lead ? [lead.id] : []} />
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
