---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getPostUrl } from "@/utils/getPostPaths";
import type { SeriesContext } from "@/utils/getSeries";
import { useTranslations, tplStr } from "@/i18n";
import config from "@/config";

interface Props {
  context: SeriesContext;
}
const { context } = Astro.props;
const { group, index, total } = context;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const seriesUrl = getRelativeLocaleUrl(locale, `series/${group.id}/`);
const partOf = tplStr(t.series.partOf, {
  title: group.title,
  total,
  order: index + 1,
});
---

<aside
  class="border-border bg-muted/40 my-8 rounded-md border p-4"
  aria-label={group.title}
>
  <p class="text-sm">
    <a
      href={seriesUrl}
      class="text-accent font-medium decoration-dashed underline-offset-4 hover:underline"
    >
      {partOf}
    </a>
  </p>

  <details class="mt-3">
    <summary class="text-muted-foreground cursor-pointer text-xs font-medium">
      {t.series.contents} ({tplStr(t.series.postCount, { count: total })})
    </summary>
    <ol class="mt-2 flex flex-col gap-1">
      {
        group.posts.map((post, i) =>
          i === index ? (
            <li
              aria-current="true"
              class="text-foreground flex items-baseline gap-2 text-sm font-semibold"
            >
              <span class="text-muted-foreground w-5 shrink-0 tabular-nums">
                {(i + 1).toString().padStart(2, "0")}
              </span>
              <span>{post.data.title}</span>
            </li>
          ) : (
            <li class="flex items-baseline gap-2 text-sm">
              <span class="text-muted-foreground w-5 shrink-0 tabular-nums">
                {(i + 1).toString().padStart(2, "0")}
              </span>
              <a
                href={getPostUrl(post.id, post.filePath, locale)}
                class="hover:text-accent decoration-dashed underline-offset-4 hover:underline"
              >
                {post.data.title}
              </a>
            </li>
          )
        )
      }
    </ol>
  </details>
</aside>
