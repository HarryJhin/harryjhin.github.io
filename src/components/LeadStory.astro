---
import { getPostUrl } from "@/utils/getPostPaths";
import config from "@/config";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
}
const { post } = Astro.props;
const { title, description, pubDatetime, section } = post.data;

// getPostUrl already applies locale routing + base prefix.
const href = getPostUrl(post.id, post.filePath);

const date = new Intl.DateTimeFormat("en-CA", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  timeZone: config.site.timezone,
}).format(pubDatetime);
---

<article class="border-border border-b pb-6">
  <div class="font-mono text-accent text-xs font-bold tracking-widest uppercase">
    Featured
  </div>
  <a href={href} class="hover:text-accent no-underline">
    <h2 class="font-display my-1 text-3xl leading-tight font-extrabold sm:text-4xl">
      {title}
    </h2>
  </a>
  {
    description && (
      <p class="font-display text-muted-foreground text-base">{description}</p>
    )
  }
  <div class="text-muted-foreground mt-2 text-xs">
    {section ? `${section} · ` : ""}{date}
  </div>
</article>
