---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import config from "@/config";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { id, data, filePath } = Astro.props;
const { title, pubDatetime, modDatetime } = data;

const href = getPostUrl(id, filePath, Astro.currentLocale);
const date = new Intl.DateTimeFormat("en-CA", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  timeZone: config.site.timezone,
}).format(modDatetime ?? pubDatetime);
---

<li>
  <a
    href={href}
    class="border-border/40 hover:text-accent group flex items-baseline gap-3 border-b py-1.5 no-underline"
  >
    <span class="group-hover:decoration-accent flex-1 text-sm decoration-dashed group-hover:underline group-hover:underline-offset-4">
      {title}
    </span>
    <span class="text-muted-foreground shrink-0 text-xs tabular-nums">{date}</span>
  </a>
</li>
