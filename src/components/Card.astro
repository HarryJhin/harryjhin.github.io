---
import type { CollectionEntry } from "astro:content";
import Byline from "./Byline.astro";
import { getPostUrl } from "@/utils/getPostPaths";
import { sectionAccent, hasAccent } from "@/utils/sectionMeta";
import config from "@/config";

interface Props {
  post: CollectionEntry<"posts">;
  variant?: "lead" | "default";
  media?: boolean;
}
const { post, variant = "default", media = false } = Astro.props;
const { title, description, pubDatetime, section } = post.data;

// getPostUrl already applies locale routing + base prefix.
const href = getPostUrl(post.id, post.filePath, Astro.currentLocale);

const date = new Intl.DateTimeFormat("en-CA", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  timeZone: config.site.timezone,
}).format(pubDatetime);

const isLead = variant === "lead";
const accent = sectionAccent(section);
const showDot = hasAccent(section);
---

<article class:list={["article-card", { lead: isLead }]} style={`--accent:${accent}`}>
  <a class="card-link" href={href}>
    {media && <span class="media" aria-hidden="true"></span>}
    <span class="body">
      {
        section && (
          <span class="kicker">
            {showDot && <span class="dot" />}
            {section}
          </span>
        )
      }
      <h3 class="hed">{title}</h3>
      {description && <p class="deck">{description}</p>}
      <Byline size="sm" date={date} class="card-byline" />
    </span>
  </a>
</article>

<style>
  .article-card {
    display: flex;
    flex-direction: column;
  }
  .card-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    text-decoration: none;
    color: inherit;
  }
  .media {
    display: block;
    height: 180px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    transition: box-shadow var(--duration-base) var(--ease-standard);
  }
  .lead .media {
    height: 320px;
  }
  .card-link:hover .media {
    box-shadow: var(--shadow-card-hover);
  }
  .body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: var(--text-kicker);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: var(--radius-full);
    background: var(--accent);
  }
  .hed {
    margin: 0;
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-subhead);
    letter-spacing: var(--tracking-heading);
    line-height: 1.1;
    color: var(--color-text-primary);
    transition: color var(--duration-fast) var(--ease-standard);
  }
  .lead .hed {
    font-size: clamp(30px, 7vw, 56px);
  }
  .card-link:hover .hed {
    color: var(--color-primary-hover);
  }
  .deck {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-read-sm);
    line-height: var(--leading-deck);
    color: var(--color-text-secondary);
  }
  .lead .deck {
    font-size: var(--text-deck);
  }
  .card-byline {
    margin-top: var(--space-1);
  }
</style>
