---
import IndexRow from "./IndexRow.astro";
import { getPostsBySection } from "@/utils/getPostsBySection";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
  excludeIds?: string[];
}
const { posts, excludeIds = [] } = Astro.props;
const groups = getPostsBySection(posts, excludeIds);
---

<div class="flex flex-col gap-8">
  {
    groups.map(group => (
      <section>
        <h2 class="font-headline text-accent mb-2 flex items-baseline gap-2 text-xl font-bold">
          <span class="opacity-40">##</span>
          {group.label}
          <span class="text-muted-foreground ms-auto text-xs font-normal">
            {group.posts.length}
          </span>
        </h2>
        {group.posts.map((post, i) => (
          <IndexRow
            num={i + 1}
            id={post.id}
            filePath={post.filePath}
            title={post.data.title}
            pubDatetime={post.data.pubDatetime}
          />
        ))}
      </section>
    ))
  }
</div>
