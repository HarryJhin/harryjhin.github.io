---
import IndexRow from "./IndexRow.astro";
import { getPostsBySection } from "@/utils/getPostsBySection";
import { getSeriesContext } from "@/utils/getSeries";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
  excludeIds?: string[];
}
const { posts, excludeIds = [] } = Astro.props;
const groups = getPostsBySection(posts, excludeIds);

function seriesProp(post: CollectionEntry<"posts">) {
  const ctx = getSeriesContext(post, posts);
  if (!ctx) return undefined;
  return {
    id: ctx.group.id,
    title: ctx.group.title,
    order: ctx.index + 1,
    total: ctx.total,
  };
}
---

<div class="flex flex-col gap-8">
  {
    groups.map(group => (
      <section id={`section-${group.id}`} class="scroll-mt-20">
        <h2 class="font-headline text-accent border-foreground/60 mb-2 flex items-baseline gap-2 border-t pt-2 text-xl font-bold tracking-wide">
          {group.label}
          <span class="font-mono text-muted-foreground ms-auto text-xs font-normal">
            {group.posts.length}
          </span>
        </h2>
        {group.posts.map((post, i) => (
          <IndexRow
            num={i + 1}
            id={post.id}
            filePath={post.filePath}
            title={post.data.title}
            pubDatetime={post.data.pubDatetime}
            series={seriesProp(post)}
          />
        ))}
      </section>
    ))
  }
</div>
