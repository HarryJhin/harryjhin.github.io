---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getCollection } from "astro:content";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconX from "@/assets/icons/IconX.svg";
import LinkButton from "./LinkButton.astro";
import SectionTag from "./SectionTag.astro";
import { stripBase, stripLocale } from "@/utils/withBase";
import { getPostSlug } from "@/utils/getPostPaths";
import { useTranslations } from "@/i18n";
import { postFilter } from "@/utils/postFilter";
import config from "@/config";

interface Props {
  variant?: "home" | "compact";
}
const { variant = "compact" } = Astro.props;

const { site, features } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const homeHref = getRelativeLocaleUrl(locale, "");

// Masthead edition line (home only)
let issueNo = 0;
let editionDate = "";
if (variant === "home") {
  const posts = (await getCollection("posts")).filter(postFilter);
  issueNo = posts.length;
  editionDate = new Intl.DateTimeFormat("en-CA", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
    timeZone: config.site.timezone,
  }).format(new Date());
}

// Strip the base prefix so isActive comparisons work regardless of deploy subdirectory.
// e.g. with base "/blog": "/blog/posts/slug" → "/posts/slug"
const relativePath = stripBase(Astro.url.pathname);
const pathWithoutTrailingSlash =
  relativePath.endsWith("/") && relativePath !== "/"
    ? relativePath.slice(0, -1)
    : relativePath;

const currentPath = stripLocale(pathWithoutTrailingSlash, locale);

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};

// On a post's own page, light up that post's section pill in the nav below.
let currentSection: string | undefined;
if (currentPath.startsWith("/posts/")) {
  const allPosts = await getCollection("posts");
  const postSlug = currentPath.replace(/^\/posts/, "");
  currentSection = allPosts.find(
    post => getPostSlug(post.id, post.filePath) === postSlug
  )?.data.section;
}

// Wordmark: last word of the site title carries the accent color.
const titleWords = site.title.split(" ");
const titleAccent = titleWords.at(-1);
const titleLead = titleWords.slice(0, -1).join(" ");

// Bottom masthead kicker — driven by the configured sections, not a hardcoded list.
const sectionKicker = config.sections.map(s => s.label.toUpperCase()).join(" · ");
---

<a id="skip-to-content" href="#main-content" class="skip-link">
  {t.a11y.skipToContent}
</a>

{
  /* Sticky nav must live outside <header> so its containing block is the
     page's own scroll flow (body), not the ~215px-tall header box — otherwise
     it un-sticks once scrolled past the header (see task-2-brief.md). */
}
{
  variant === "home" && (
    <header class="masthead">
      <div class="masthead-inner">
        <div class="masthead-kicker">
          <span>The JVM Ecosystem, Indexed</span>
          <span>
            {editionDate} · Issue {issueNo}
          </span>
        </div>
        <a href={homeHref} class="wordmark wordmark-lg">
          <h1>
            {titleLead && `${titleLead} `}
            <span class="accent">{titleAccent}</span>
          </h1>
        </a>
        <p class="masthead-sections">{sectionKicker}</p>
      </div>
    </header>
  )
}

<div class="section-nav">
  <div class="section-nav-inner">
    {
      variant !== "home" && (
        <a href={homeHref} class="wordmark wordmark-sm">
          {titleLead && `${titleLead} `}
          <span class="accent">{titleAccent}</span>
        </a>
      )
    }
    <nav id="nav-menu" aria-label={t.nav.posts}>
      <button
        id="menu-btn"
        class="menu-btn"
        aria-label={t.a11y.openMenu}
        aria-expanded="false"
        aria-controls="menu-items"
        data-label-open={t.a11y.openMenu}
        data-label-close={t.a11y.closeMenu}
      >
        <IconX id="close-icon" class="hidden menu-btn-icon" />
        <IconMenuDeep id="menu-icon" class="menu-btn-icon" />
      </button>
      <ul id="menu-items" class="hidden menu-items">
        {
          config.sections.map(s => {
            // Active when viewing a post in this section, or the section's own
            // listing page (`/posts/{id}` or a later `/posts/{id}/{page}`).
            const isSectionPage =
              currentPath === `/posts/${s.id}` ||
              currentPath.startsWith(`/posts/${s.id}/`);
            const active = currentSection === s.id || isSectionPage;
            return (
              <li class="pill-item">
                <a
                  href={getRelativeLocaleUrl(locale, `posts/${s.id}`)}
                  class="pill-link"
                  aria-current={active ? "page" : undefined}
                >
                  <SectionTag section={s.id} active={active}>
                    {s.label}
                  </SectionTag>
                </a>
              </li>
            );
          })
        }
        <li class="nav-start">
          <a
            href={getRelativeLocaleUrl(locale, "posts")}
            class:list={["nav-link", { active: isActive("/posts") }]}
            aria-current={isActive("/posts") ? "page" : undefined}
          >
            {t.nav.posts}
          </a>
        </li>
        <li>
          <a
            href={getRelativeLocaleUrl(locale, "tags")}
            class:list={["nav-link", { active: isActive("/tags") }]}
            aria-current={isActive("/tags") ? "page" : undefined}
          >
            {t.nav.tags}
          </a>
        </li>
        <li>
          <a
            href={getRelativeLocaleUrl(locale, "series")}
            class:list={["nav-link", { active: isActive("/series") }]}
            aria-current={isActive("/series") ? "page" : undefined}
          >
            {t.nav.series}
          </a>
        </li>
        <li>
          <a
            href={getRelativeLocaleUrl(locale, "about")}
            class:list={["nav-link", { active: isActive("/about") }]}
            aria-current={isActive("/about") ? "page" : undefined}
          >
            {t.nav.about}
          </a>
        </li>
        {
          features.showArchives && (
            <li>
              <LinkButton
                href={getRelativeLocaleUrl(locale, "archives")}
                class:list={["icon-link", { active: isActive("/archives") }]}
                title={t.nav.archives}
                aria-label={t.nav.archives}
                aria-current={isActive("/archives") ? "page" : undefined}
              >
                <IconArchive class="icon-svg" aria-hidden="true" />
                <span class="icon-label">{t.nav.archives}</span>
              </LinkButton>
            </li>
          )
        }
        {
          features.search !== false && (
            <li>
              <LinkButton
                href={getRelativeLocaleUrl(locale, "search")}
                class:list={["icon-link", { active: isActive("/search") }]}
                title={t.nav.search}
                aria-label={t.nav.search}
                aria-current={isActive("/search") ? "page" : undefined}
              >
                <IconSearch class="icon-svg" aria-hidden="true" />
                <span class="icon-label">{t.nav.search}</span>
              </LinkButton>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</div>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector<HTMLButtonElement>("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    const openLabel = menuBtn.dataset.labelOpen ?? "Open menu";
    const closeLabel = menuBtn.dataset.labelClose ?? "Close menu";

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? openLabel : closeLabel);

      menuItems.classList.toggle("hidden");
      menuItems.classList.toggle("grid");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();

  document.addEventListener("astro:after-swap", toggleNav);
</script>

<style>
  .skip-link {
    position: absolute;
    z-index: 50;
    top: -9999px;
    inset-inline-start: var(--space-4);
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface);
    color: var(--color-primary);
    border-radius: var(--radius-sm);
    text-decoration: none;
  }
  .skip-link:focus {
    top: var(--space-4);
  }

  /* Home masthead — DS FrontPage banner */
  .masthead {
    border-top: 2px solid var(--color-text-primary);
    border-bottom: 1px solid var(--color-border);
  }
  .masthead-inner {
    max-width: 1120px;
    margin-inline: auto;
    padding: 14px var(--space-4);
  }
  .masthead-kicker {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--text-overline);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
  }
  .masthead-sections {
    margin: var(--space-1) 0 0;
    text-align: center;
    font-family: var(--font-sans);
    font-size: var(--text-overline);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }

  /* Wordmark — shared between the home masthead and the sticky inner nav */
  .wordmark {
    display: block;
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    white-space: nowrap;
  }
  .wordmark .accent {
    color: var(--color-primary);
  }
  .wordmark-lg {
    text-align: center;
    white-space: normal;
  }
  .wordmark-lg h1 {
    margin: 0;
    padding: var(--space-2) 0;
    font-family: inherit;
    font-weight: inherit;
    color: inherit;
    font-size: clamp(32px, 12vw, 44px);
    letter-spacing: -0.04em;
  }
  .wordmark-sm {
    font-size: 18px;
    letter-spacing: var(--tracking-heading);
  }

  /* Sticky section nav — DS NavBar */
  .section-nav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }
  .section-nav-inner {
    max-width: 1120px;
    margin-inline: auto;
    padding: var(--space-3) var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .section-nav-inner nav {
    flex: 1;
    min-width: 0;
  }

  .menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-text-primary);
  }
  .menu-btn-icon {
    width: 22px;
    height: 22px;
  }

  .menu-items {
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--space-4);
    align-items: center;
  }

  .pill-link {
    display: inline-flex;
    text-decoration: none;
    border-radius: var(--radius-full);
  }
  .pill-link:hover :global(.section-tag) {
    background: var(--color-border);
  }
  .pill-link:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding-block: 2px;
    border-bottom: 2px solid transparent;
    transition:
      color var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard);
  }
  .nav-link:hover {
    color: var(--color-primary-hover);
  }
  .nav-link.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  .icon-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    transition: color var(--duration-fast) var(--ease-standard);
  }
  .icon-link:hover {
    color: var(--color-primary-hover);
  }
  .icon-link.active {
    color: var(--color-primary);
  }
  .icon-svg {
    display: none;
  }

  /* Mobile drawer (<768px): menu button opens a vertical stack of section
     pills + utility links (JS toggles the "hidden"/"grid" Tailwind utilities
     on #menu-items — see <script> below). */
  @media (max-width: 767.98px) {
    #menu-items.grid {
      padding-block: var(--space-4);
      border-top: 1px solid var(--color-border);
    }
  }

  /* Desktop (>=768px): everything sits in one row; utility links push to the
     far end via margin-inline-start:auto on the first non-pill item. */
  @media (min-width: 768px) {
    .menu-btn {
      display: none;
    }
    #menu-items {
      display: flex !important;
      flex-direction: row;
    }
    .nav-start {
      margin-inline-start: auto;
    }
    .icon-link {
      width: 32px;
      height: 32px;
      justify-content: center;
    }
    .icon-svg {
      display: block;
      width: 20px;
      height: 20px;
    }
    .icon-label {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }
</style>
