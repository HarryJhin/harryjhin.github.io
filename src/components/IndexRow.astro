---
import { getPostUrl } from "@/utils/getPostPaths";
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

interface Props {
  num: number;
  id: string;
  filePath?: string;
  title: string;
  pubDatetime: Date;
  series?: { id: string; title: string; order: number; total: number };
}
const { num, id, filePath, title, pubDatetime, series } = Astro.props;

// getPostUrl already applies locale routing + base prefix.
const href = getPostUrl(id, filePath);

const locale = Astro.currentLocale ?? config.site.lang;
const seriesHref = series
  ? getRelativeLocaleUrl(locale, `series/${series.id}/`)
  : undefined;

const mmdd = new Intl.DateTimeFormat("en-CA", {
  month: "2-digit",
  day: "2-digit",
  timeZone: config.site.timezone,
}).format(pubDatetime);
---

<div class="border-border/40 group flex items-baseline gap-3 border-b py-1.5">
  <span class="text-muted-foreground w-6 shrink-0 text-sm tabular-nums">
    {num.toString().padStart(2, "0")}
  </span>
  <span class="flex-1 text-sm">
    <a
      href={href}
      class="hover:text-accent decoration-dashed underline-offset-4 hover:underline"
    >
      {title}
    </a>
    {
      series && (
        <a
          href={seriesHref}
          class="text-accent/80 hover:text-accent ms-1 align-middle text-xs whitespace-nowrap no-underline"
          title={series.title}
        >
          ◆ {series.title} {series.order}/{series.total}
        </a>
      )
    }
  </span>
  <span class="text-muted-foreground shrink-0 text-xs tabular-nums">{mmdd}</span>
</div>
