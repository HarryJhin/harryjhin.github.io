---
interface Props {
  title?: string;
  subtitle?: string;
  href?: string;
  divider?: boolean;
  class?: string;
}
const { title, subtitle, href, divider = true, class: cls, ...attrs } = Astro.props;

const isLink = Boolean(href);
const hasLeading = Astro.slots.has("leading");
const hasTrailing = Astro.slots.has("trailing");
---

{
  isLink ? (
    <a href={href} class:list={["ds-list-row", "interactive", divider && "divider", cls]} {...attrs}>
      <div class="left">
        {
          hasLeading && (
            <span class="leading">
              <slot name="leading" />
            </span>
          )
        }
        <div class="text">
          {title && <p class="title">{title}</p>}
          {subtitle && <p class="subtitle">{subtitle}</p>}
        </div>
      </div>
      {
        hasTrailing && (
          <div class="trailing">
            <slot name="trailing" />
          </div>
        )
      }
    </a>
  ) : (
    <div class:list={["ds-list-row", divider && "divider", cls]} {...attrs}>
      <div class="left">
        {
          hasLeading && (
            <span class="leading">
              <slot name="leading" />
            </span>
          )
        }
        <div class="text">
          {title && <p class="title">{title}</p>}
          {subtitle && <p class="subtitle">{subtitle}</p>}
        </div>
      </div>
      {
        hasTrailing && (
          <div class="trailing">
            <slot name="trailing" />
          </div>
        )
      }
    </div>
  )
}

<style>
  .ds-list-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: 12px 16px;
    background: transparent;
    text-decoration: none;
    color: inherit;
    transition: background var(--duration-fast) var(--ease-standard);
  }

  .ds-list-row.divider {
    border-bottom: 1px solid var(--color-border);
  }

  .ds-list-row.interactive {
    cursor: pointer;
  }
  .ds-list-row.interactive:hover {
    background: var(--color-bg-alt);
  }

  .left {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  .leading {
    display: inline-flex;
    flex-shrink: 0;
  }

  .text {
    min-width: 0;
  }

  .title {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .subtitle {
    margin: 1px 0 0;
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
  }

  .trailing {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }
</style>
